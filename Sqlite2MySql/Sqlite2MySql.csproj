<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Sqlite2MySql</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <AssemblyName>sqlite2mysql</AssemblyName>
    <Version>1.0.0</Version>
    <ApplicationIcon>Assets\sqlite2mysql.ico</ApplicationIcon>
    <Description>SQLite to MySQL converter - cross-platform CLI and GUI (Windows, Linux, macOS)</Description>
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.2.2" />
    <PackageReference Include="Avalonia.Desktop" Version="11.2.2" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.2.2" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.3" />
  </ItemGroup>

</Project>
